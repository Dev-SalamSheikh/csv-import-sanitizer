{
  "name": "csv-import-sanitizer",
  "version": "1.0.0",
  "description": "Secure, production-ready utility to sanitize, normalize, validate, and transform CSV import data for SaaS applications.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'test/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts'",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "csv",
    "sanitize",
    "sanitizer",
    "import",
    "validate",
    "normalize",
    "csv-parser",
    "csv-import",
    "data-validation",
    "csv-injection",
    "security",
    "saas"
  ],
  "author": "MD. Abdus Salam <[EMAIL_ADDRESS]>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dev-Salamsheikh/csv-import-sanitizer"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "papaparse": "^5.4.1"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.14",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
